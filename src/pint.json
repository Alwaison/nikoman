{
    "preset": "laravel",
    "rules": {
        "declare_strict_types": true,
        "ordered_imports": {
            "sort_algorithm": "alpha"
        },
        "no_unused_imports": true,
        "single_quote": true,
        "blank_line_before_statement": {
            "statements": ["return", "throw", "try", "if"]
        },
        "method_chaining_indentation": true,
        "no_superfluous_phpdoc_tags": true,
        "phpdoc_trim": true
    }
}
